---
import Layout from '../../layouts/Layout.astro';
import CTASection from '../../components/CTASection.astro';
import CommunityCard from '../../components/CommunityCard.astro';
import { communities } from '../../data/communities';

export function getStaticPaths() {
  return communities.map((community) => ({
    params: { slug: community.slug },
    props: { community },
  }));
}

const { community } = Astro.props;
const related = communities.filter((item) => item.slug !== community.slug).slice(0, 3);
---

<Layout title={`${community.name} Real Estate | Scott Homes Topsail`} description={`${community.summary} Get local ${community.name} real estate guidance from Tad Scott Homes.`} image={community.image}>
  <section class="relative overflow-hidden bg-sky-950 px-4 py-20 text-white sm:px-6 lg:px-8">
    <img class="absolute inset-0 h-full w-full object-cover opacity-42" src={community.image} alt="" />
    <div class="absolute inset-0 bg-gradient-to-r from-sky-950/92 via-sky-950/62 to-sky-950/20"></div>
    <div class="relative mx-auto max-w-7xl">
      <p class="text-sm font-black uppercase tracking-wide text-sky-200">Community guide</p>
      <h1 class="mt-3 text-4xl font-black sm:text-5xl">{community.name}</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-sky-50/88">{community.summary}</p>
    </div>
  </section>

  <section class="px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="space-y-5 text-base leading-8 text-slate-650">
        <h2 class="text-3xl font-black text-sky-950">What to know about {community.name}</h2>
        <p>{community.summary}</p>
        <p>For buyers, the right fit often depends on pace of life, beach or mainland access, property type, budget, and how you plan to use the home. For sellers, local pricing and presentation matter because each Topsail-area community has its own demand patterns.</p>
        <p>Tad Scott can help compare this community against nearby options and give you a practical read on current opportunities.</p>
      </div>
      <aside class="rounded-sm border border-sky-950/10 bg-sky-50 p-6">
        <h2 class="text-xl font-black text-sky-950">Highlights</h2>
        <ul class="mt-4 space-y-3">
          {community.highlights.map((highlight) => (
            <li class="rounded-sm bg-white px-4 py-3 text-sm font-bold text-slate-700 shadow-sm">{highlight}</li>
          ))}
        </ul>
      </aside>
    </div>
  </section>

  <section class="bg-sand px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <h2 class="text-3xl font-black text-sky-950">Compare nearby communities</h2>
      <div class="mt-6 grid gap-5 md:grid-cols-3">
        {related.map((item) => <CommunityCard community={item} />)}
      </div>
    </div>
  </section>

  <CTASection eyebrow={`Considering ${community.name}?`} title="Get a local read before you make your next move." />
</Layout>

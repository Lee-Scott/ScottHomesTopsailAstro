---
import Layout from '../layouts/Layout.astro';
import ContactBlock from '../components/ContactBlock.astro';
import { business } from '../data/site';
---

<Layout title="Free Home Valuation | Scott Homes Topsail Island" description="Request a free local home valuation from Tad Scott for Topsail Beach, Surf City, North Topsail Beach, Wilmington, and surrounding coastal markets.">
  <section class="relative overflow-hidden bg-sky-950 px-4 py-20 text-white sm:px-6 lg:px-8">
    <img class="absolute inset-0 h-full w-full object-cover opacity-20" src="/assets/surf-city-bridge.webp" alt="" />
    <div class="absolute inset-0 bg-linear-to-r from-sky-950/95 via-sky-950/82 to-sky-900/55"></div>
    <div class="relative mx-auto max-w-7xl">
      <p class="text-sm font-black uppercase tracking-wide text-sky-200">Free Home Valuation</p>
      <h1 class="mt-3 max-w-4xl text-4xl font-black sm:text-5xl">Get a free local valuation conversation with clearer market context.</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-sky-50/90">If you are considering a sale in Topsail Beach, Surf City, North Topsail Beach, Wilmington, or nearby markets, Tad can review your property directly and talk through pricing, timing, preparation, and what buyers are responding to right now.</p>
    </div>
  </section>

  <section class="px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1.2fr_0.8fr]">
      <div class="space-y-6 text-base leading-8 text-slate-650">
        <h2 class="text-3xl font-black text-sky-950">What you get</h2>
        <p>A practical review of your home using comparable sales, neighborhood context, condition, presentation, and current buyer demand. The goal is to give you a grounded local opinion before you make decisions about selling.</p>
        <div class="grid gap-4 sm:grid-cols-2">
          {['Comparable local sales review', 'Pricing and timing discussion', 'Preparation and presentation advice', 'Direct call or email follow-up'].map((item) => (
            <div class="rounded-sm border border-sky-950/10 bg-sky-50 p-4 font-bold text-sky-950">{item}</div>
          ))}
        </div>
        <p>Call or email Tad directly for a free local valuation conversation based on comparable sales, neighborhood context, condition, presentation, and current buyer demand.</p>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a class="rounded-sm bg-sky-950 px-5 py-3 text-center text-sm font-black text-white hover:bg-sky-800" href={business.phoneHref}>Call {business.phone}</a>
          <a class="rounded-sm border border-sky-950/15 px-5 py-3 text-center text-sm font-black text-sky-950 hover:border-sky-700" href={business.emailHref}>Email {business.email}</a>
        </div>
      </div>
      <ContactBlock eyebrow="Free local valuation" title="Start the conversation directly." text="Reach Tad for a practical local valuation conversation based on recent comparable sales and current buyer demand." />
    </div>
  </section>
</Layout>

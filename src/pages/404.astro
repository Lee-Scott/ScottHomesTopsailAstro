---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found | Scott Homes" description="This Scott Homes page could not be found.">
  <section class="bg-sand px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-black uppercase tracking-wide text-sky-700">404</p>
      <h1 class="mt-3 text-4xl font-black text-sky-950 sm:text-5xl">Page not found</h1>
      <p class="mt-5 text-base leading-7 text-slate-650">The page may have moved during the rebuild. Use the links below to get back to the main site.</p>
      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a class="rounded-sm bg-sky-950 px-5 py-3 text-center text-sm font-black text-white hover:bg-sky-800" href="/">Home</a>
        <a class="rounded-sm border border-sky-950/15 px-5 py-3 text-center text-sm font-black text-sky-950 hover:border-sky-700" href="/contact/">Contact Tad</a>
      </div>
    </div>
  </section>
</Layout>

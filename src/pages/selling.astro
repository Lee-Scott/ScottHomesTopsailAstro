---
import Layout from '../layouts/Layout.astro';
import RecentSalesTable from '../components/RecentSalesTable.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="Selling Topsail Island Real Estate | Scott Homes" description="Sell your Topsail Island or coastal North Carolina home with local pricing, presentation, and marketing guidance from Tad Scott Homes.">
  <section class="bg-sky-950 px-4 py-16 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="text-sm font-black uppercase tracking-wide text-sky-200">Selling</p>
        <h1 class="mt-3 text-4xl font-black sm:text-5xl">Price it clearly, present it well, and stay proactive.</h1>
        <p class="mt-5 text-lg leading-8 text-sky-50/88">Selling homes on Topsail is a specialty. Tad focuses on local pricing, strong presentation, open house exposure, and direct follow-through from listing to contract.</p>
      </div>
      <img class="h-[420px] w-full rounded-sm object-cover shadow-xl shadow-black/20" src="/assets/selling-home.webp" alt="Open house sign" />
    </div>
  </section>
  <RecentSalesTable />
  <CTASection eyebrow="Thinking about selling?" title="Get a free local valuation before you list." primaryLabel="Free Home Valuation" primaryHref="/free-home-valuation/" />
</Layout>

---
import { business } from '../data/site';

const {
  eyebrow = 'Ready for a local read on the market?',
  title = 'Talk directly with Tad Scott.',
  text = 'Call or email for a straightforward conversation about buying, selling, valuing, or building in the Topsail area.',
  primaryLabel = 'Call 919-360-6754',
  primaryHref = business.phoneHref,
  secondaryLabel = 'Email Tad',
  secondaryHref = business.emailHref,
} = Astro.props;
---

<section class="bg-sky-950 px-4 py-16 text-white sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl rounded-lg border border-sky-700 bg-gradient-to-br from-sky-900 to-sky-950 px-6 py-10 shadow-2xl sm:px-8">
    <div class="grid gap-8 lg:grid-cols-[1.3fr_auto] lg:items-center">
      <div>
        <p class="text-sm font-black uppercase tracking-wide text-sky-300">{eyebrow}</p>
        <h2 class="mt-3 text-3xl font-black tracking-normal sm:text-4xl text-white">{title}</h2>
        <p class="mt-4 max-w-3xl text-base leading-7 text-sky-100">{text}</p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
        <a class="rounded-lg bg-sky-400 px-6 py-3 text-center text-sm font-black text-sky-950 transition hover:bg-sky-300 shadow-lg" href={primaryHref}>{primaryLabel}</a>
        <a class="rounded-lg border-2 border-sky-300 bg-sky-800 px-6 py-3 text-center text-sm font-black text-white transition hover:border-white hover:bg-sky-700" href={secondaryHref}>{secondaryLabel}</a>
      </div>
    </div>
  </div>
</section>

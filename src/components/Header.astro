---
import { business, navItems } from '../data/site';
---

<header class="sticky top-0 z-50 border-b border-sky-950/10 bg-white/92 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-5 px-4 py-3 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-3" aria-label="Scott Homes home">
      <img class="h-12 w-auto shrink-0 object-contain sm:h-14" src="/assets/scott-homes-logo.png" alt="Scott Homes logo" />
      <span class="leading-tight">
        <span class="block text-sm font-black uppercase tracking-wide text-sky-950">{business.brand}</span>
        <span class="block text-xs font-semibold text-slate-500">Topsail Island Real Estate</span>
      </span>
    </a>
    <nav class="hidden items-center gap-5 text-sm font-bold text-slate-700 lg:flex" aria-label="Primary navigation">
      {navItems.map((item) => <a class="transition hover:text-sky-700" href={item.href}>{item.label}</a>)}
    </nav>
    <div class="flex items-center gap-2">
      <a class="hidden rounded-sm border border-sky-950/15 px-3 py-2 text-sm font-bold text-sky-950 transition hover:border-sky-600 hover:text-sky-700 sm:inline-flex" href={business.phoneHref}>
        {business.phone}
      </a>
      <a class="rounded-sm bg-sky-950 px-4 py-2 text-sm font-black text-white transition hover:bg-sky-800" href="/free-home-valuation/">
        Free Home Valuation
      </a>
    </div>
  </div>
  <nav class="no-scrollbar flex gap-4 overflow-x-auto border-t border-sky-950/10 px-4 py-2 text-xs font-bold text-slate-700 lg:hidden" aria-label="Mobile navigation">
    {navItems.map((item) => <a class="shrink-0" href={item.href}>{item.label}</a>)}
  </nav>
</header>

---
import { business } from '../data/site';

const {
  eyebrow = 'Ready for a local read on the market?',
  title = 'Talk directly with Tad Scott.',
  text = 'Call or email for a straightforward conversation about buying, selling, valuing, or building in the Topsail area.',
  primaryLabel = 'Call 919-360-6754',
  primaryHref = business.phoneHref,
  secondaryLabel = 'Email Tad',
  secondaryHref = business.emailHref,
} = Astro.props;
---

<section class="bg-sky-950 px-4 py-14 text-white sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl rounded-sm border border-sky-300/20 bg-sky-900 px-6 py-8 shadow-xl shadow-black/20 sm:px-8">
    <div class="grid gap-6 lg:grid-cols-[1.3fr_auto] lg:items-center">
      <div>
        <p class="text-sm font-black uppercase tracking-wide text-sky-200">{eyebrow}</p>
        <h2 class="mt-3 text-3xl font-black tracking-normal sm:text-4xl">{title}</h2>
        <p class="mt-4 max-w-3xl text-base leading-7 text-sky-50/92">{text}</p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
        <a class="rounded-sm bg-sky-300 px-5 py-3 text-center text-sm font-black text-sky-950 transition hover:bg-sky-200" href={primaryHref}>{primaryLabel}</a>
        <a class="rounded-sm border border-sky-200/40 bg-white px-5 py-3 text-center text-sm font-black text-sky-950 transition hover:border-white hover:bg-sky-100" href={secondaryHref}>{secondaryLabel}</a>
      </div>
    </div>
  </div>
</section>

---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="Buying Topsail Island Real Estate | Scott Homes" description="Buy a home on Topsail Island or nearby coastal North Carolina markets with local guidance from Tad Scott Homes.">
  <section class="bg-sand px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="text-sm font-black uppercase tracking-wide text-sky-700">Buying</p>
        <h1 class="mt-3 text-4xl font-black text-sky-950 sm:text-5xl">Understand the coast before you commit.</h1>
        <p class="mt-5 text-lg leading-8 text-slate-650">Buying a home at the coast is different. Beach access, bridges, flood considerations, rental potential, lot position, insurance, and construction quality all matter. Tad brings local investor, builder, and Realtor experience to the search.</p>
      </div>
      <img class="h-[420px] w-full rounded-sm object-cover shadow-xl shadow-sky-950/12" src="/assets/beach-walk.webp" alt="Family walking along a North Carolina beach" />
    </div>
  </section>
  <section class="px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-6 md:grid-cols-3">
      {[
        ['Neighborhood fit', 'Compare Topsail Beach, Surf City, North Topsail Beach, Hampstead, Sneads Ferry, Wilmington, and other nearby options.'],
        ['Property review', 'Talk through home condition, location tradeoffs, rental potential, and long-term ownership considerations.'],
        ['Offer strategy', 'Use current local context to make a practical offer and move through the purchase process with fewer surprises.'],
      ].map(([title, text]) => (
        <article class="rounded-sm border border-sky-950/10 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-black text-sky-950">{title}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-600">{text}</p>
        </article>
      ))}
    </div>
  </section>
  <CTASection eyebrow="Buying on Topsail?" title="Start with a local conversation." />
</Layout>

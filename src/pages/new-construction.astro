---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="New Construction Topsail Island | Scott Homes" description="Plan a new construction coastal home with guidance from Tad Scott Homes, backed by decades of local development and building experience.">
  <section class="bg-sand px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="text-sm font-black uppercase tracking-wide text-sky-700">New Construction</p>
        <h1 class="mt-3 text-4xl font-black text-sky-950 sm:text-5xl">Build with a clearer view of the process.</h1>
        <p class="mt-5 text-lg leading-8 text-slate-650">Since 1999, Tad has been developing real estate on Topsail. He helps clients understand lots, plans, builders, materials, and the practical choices that shape a coastal home.</p>
      </div>
      <img class="h-[420px] w-full rounded-sm object-cover shadow-xl shadow-sky-950/12" src="/assets/new-construction.webp" alt="New construction home" />
    </div>
  </section>
  <section class="px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-6 md:grid-cols-3">
      {[
        ['Lot and location', 'Understand access, exposure, elevation, buildability, and neighborhood context before moving forward.'],
        ['Builder guidance', 'Talk through builder quality, materials, timeline, and the questions that matter before construction starts.'],
        ['Coastal practicals', 'Plan around beach conditions, insurance considerations, durability, and long-term ownership goals.'],
      ].map(([title, text]) => (
        <article class="rounded-sm border border-sky-950/10 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-black text-sky-950">{title}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-600">{text}</p>
        </article>
      ))}
    </div>
    <div class="mx-auto mt-8 grid max-w-7xl gap-5 md:grid-cols-2">
      <img class="h-72 w-full rounded-sm object-cover" src="/assets/construction-detail.jpg" alt="Construction detail" loading="lazy" />
      <img class="h-72 w-full rounded-sm object-cover" src="/assets/construction-site.jpg" alt="Construction site" loading="lazy" />
    </div>
  </section>
  <CTASection eyebrow="Planning a build?" title="Talk through the lot, builder, and process first." />
</Layout>

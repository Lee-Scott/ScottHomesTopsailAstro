---
const { community } = Astro.props;
---

<article class="group overflow-hidden rounded-sm border border-sky-950/10 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-md hover:shadow-sky-950/10">
  <img class="h-24 w-full object-cover" src={community.image} alt="" loading="lazy" />
  <div class="flex flex-col p-3">
    <h3 class="text-base font-black text-sky-950">{community.name}</h3>
    <p class="mt-1.5 text-xs leading-5 text-slate-600 flex-grow">{community.summary.slice(0, 100)}...</p>
    <a class="mt-2 inline-flex text-xs font-black text-sky-700 hover:text-sky-950 transition" href={`/communities/${community.slug}/`}>Explore →</a>
  </div>
</article>

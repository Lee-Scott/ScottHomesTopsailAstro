---
const { community } = Astro.props;
---

<article class="group overflow-hidden rounded-sm border border-sky-950/10 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl hover:shadow-sky-950/10">
  <img class="h-44 w-full object-cover" src={community.image} alt="" />
  <div class="flex min-h-[252px] flex-col p-5">
    <h3 class="text-xl font-black text-sky-950">{community.name}</h3>
    <p class="mt-3 text-sm leading-6 text-slate-600">{community.summary}</p>
    <a class="mt-auto inline-flex pt-5 text-sm font-black text-sky-700 hover:text-sky-950" href={`/communities/${community.slug}/`}>Explore {community.name}</a>
  </div>
</article>

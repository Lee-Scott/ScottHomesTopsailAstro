---
import { business, navItems } from '../data/site';
---

<footer class="bg-sky-950 text-white">
  <section class="border-b border-white/10">
    <div class="mx-auto grid max-w-7xl gap-6 px-4 py-6 sm:px-6 lg:grid-cols-[1.4fr_1fr_1fr] lg:items-start lg:px-8">
      <div class="space-y-2">
        <div class="flex items-center gap-3">
          <img class="h-12 w-auto rounded-sm bg-white p-1" src="/assets/scott-homes-logo.png" alt="Scott Homes logo" />
          <div>
            <p class="text-sm font-black uppercase tracking-wide text-sky-300">Scott Homes</p>
            <p class="text-xs font-bold text-sky-100">Topsail Island Real Estate</p>
          </div>
        </div>
        <p class="max-w-2xl text-sm font-semibold text-white">
          Local guidance for buying, selling, free valuation, and new construction along the Topsail coast.
        </p>
      </div>
      <div class="space-y-2 text-sm">
        <p class="text-xs font-black uppercase tracking-wide text-sky-300">Call or email</p>
        <a class="inline-flex items-center gap-1.5 font-bold text-sky-200 transition hover:text-white hover:underline" href={business.phoneHref}>
          <span class="text-base">📞</span> {business.phone}
        </a>
        <br />
        <a class="inline-flex items-center gap-1.5 font-bold text-sky-200 transition hover:text-white hover:underline" href={business.emailHref}>
          <span class="text-base">✉️</span> {business.email}
        </a>
      </div>
      <div class="space-y-2 text-sm">
        <p class="text-xs font-black uppercase tracking-wide text-sky-300">Profiles</p>
        <a class="inline-flex items-center gap-1.5 font-bold text-sky-200 transition hover:text-white hover:underline" href={business.facebook} target="_blank" rel="noopener noreferrer">
          <span class="text-base">🔗</span> Facebook
        </a>
        <br />
        <a class="inline-flex items-center gap-1.5 font-bold text-sky-200 transition hover:text-white hover:underline" href={business.zillow} target="_blank" rel="noopener noreferrer">
          <span class="text-base">🔗</span> Zillow
        </a>
      </div>
    </div>
  </section>
  <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-4 text-xs sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
    <p class="font-semibold text-sky-100">(c) 2026 Scott Homes</p>
    <nav class="flex flex-wrap gap-x-4 gap-y-2 text-sky-100" aria-label="Footer navigation">
      {navItems.map((item) => <a class="font-bold transition hover:text-white" href={item.href}>{item.label}</a>)}
    </nav>
  </div>
</footer>

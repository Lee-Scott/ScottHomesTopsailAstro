// wrangler.jsonc
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "scotthomestopsail",
  "compatibility_date": "2026-06-06",
  "assets": {
    "directory": "./dist"
  },
  "routes": [
    {
      "pattern": "scotthomestopsail.com",
      "custom_domain": true
    },
    {
      "pattern": "www.scotthomestopsail.com",
      "custom_domain": true
    }
  ]
}
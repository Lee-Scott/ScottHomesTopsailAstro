---
import Layout from '../layouts/Layout.astro';
import ContactBlock from '../components/ContactBlock.astro';
import { business } from '../data/site';
---

<Layout title="Contact Tad Scott | Scott Homes Topsail Island" description="Contact Tad Scott Homes for Topsail Island real estate, free home valuation, buying, selling, and new construction guidance.">
  <section class="bg-sand px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <p class="text-sm font-black uppercase tracking-wide text-sky-700">Contact</p>
      <h1 class="mt-3 max-w-4xl text-4xl font-black text-sky-950 sm:text-5xl">Reach out directly for the next step in Topsail real estate.</h1>
      <p class="mt-5 max-w-4xl text-lg leading-8 text-slate-650">Visitors can reach out directly for buying, selling, free valuation, new construction, or Topsail-area community questions. The goal is a straightforward conversation grounded in local experience, current market context, and what makes sense for your next move.</p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
      <div>
        <div class="grid gap-5 md:grid-cols-2">
          {[
            ['Buying questions', 'Talk through neighborhoods, property fit, beach versus mainland options, and how to approach the search with local context.'],
            ['Selling / valuation questions', 'Discuss timing, comparable sales, pricing, presentation, and what buyers are responding to right now.'],
            ['New construction questions', 'Work through lots, builders, plans, materials, process, and practical decisions for coastal construction.'],
            ['Local community questions', 'Compare Topsail Island communities and nearby coastal markets to understand the fit for your lifestyle and goals.'],
          ].map(([title, text]) => (
            <article class="rounded-sm border border-sky-950/10 bg-white p-6 shadow-sm">
              <h2 class="text-2xl font-black text-sky-950">{title}</h2>
              <p class="mt-3 text-sm leading-7 text-slate-650">{text}</p>
            </article>
          ))}
        </div>
      </div>
      <ContactBlock eyebrow="Contact Tad Scott" title="Call or email directly." text="For buying, selling, free valuation, new construction, or local community questions, reach Tad directly and start with a clear local conversation." />
    </div>
  </section>

  <section class="bg-sky-50 px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <p class="text-sm font-black uppercase tracking-wide text-sky-700">Best reasons to reach out</p>
        <h2 class="mt-3 text-3xl font-black text-sky-950 sm:text-4xl">A direct local conversation is usually the fastest next step.</h2>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        {[
          ['Buying plans', 'Compare island and mainland options, talk timing, and narrow the right search strategy before you spend time on the wrong inventory.'],
          ['Selling decisions', 'Pressure-test price, timing, and presentation against recent comparable sales and what buyers are actually rewarding right now.'],
          ['New construction', 'Talk through lots, builders, flood-zone realities, finish decisions, and how coastal construction choices affect value and maintenance.'],
          ['Community fit', 'Get a practical read on Surf City, Topsail Beach, North Topsail, Hampstead, Sneads Ferry, Wilmington, and nearby coastal neighborhoods.'],
        ].map(([title, text]) => (
          <article class="rounded-sm border border-sky-950/10 bg-white p-6 shadow-sm shadow-sky-950/5">
            <h3 class="text-xl font-black text-sky-950">{title}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-650">{text}</p>
          </article>
        ))}
      </div>
      <div class="mt-8 rounded-sm border border-sky-950/10 bg-white px-6 py-5 shadow-sm shadow-sky-950/5">
        <p class="text-sm leading-7 text-slate-650">
          Reach out directly by phone or email for buying, selling, free valuation, new construction, or local community questions.
          <a class="ml-2 font-black text-sky-700 hover:text-sky-950" href={business.phoneHref}>Call {business.phone}</a>
          <span class="mx-2 text-slate-300">|</span>
          <a class="font-black text-sky-700 hover:text-sky-950" href={business.emailHref}>Email Tad</a>
        </p>
      </div>
    </div>
  </section>
</Layout>

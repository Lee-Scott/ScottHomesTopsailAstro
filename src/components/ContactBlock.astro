---
import { business } from '../data/site';

const {
  eyebrow = 'Talk with Tad directly',
  title = 'Call, email, or explore the right next step.',
  text = 'Reach out for buying, selling, free valuation, new construction, or Topsail-area community questions.',
} = Astro.props;
---

<aside class="overflow-hidden rounded-sm border border-sky-950/10 bg-white shadow-lg shadow-sky-950/10">
  <div class="bg-sky-950 px-6 py-6 text-white">
    <p class="text-sm font-black uppercase tracking-wide text-sky-200">{eyebrow}</p>
    <h2 class="mt-2 text-2xl font-black">{title}</h2>
    <p class="mt-3 text-sm leading-6 text-sky-50/90">{text}</p>
  </div>
  <div class="grid gap-4 bg-white p-6">
    <a class="rounded-sm bg-sky-300 px-5 py-4 text-center text-base font-black text-sky-950 shadow-sm transition hover:bg-sky-200" href={business.phoneHref}>
      Call Tad Scott
      <span class="mt-1 block text-sm font-bold">{business.phone}</span>
    </a>
    <a class="rounded-sm border border-sky-950/20 bg-sky-950 px-5 py-4 text-center text-base font-black text-white transition hover:bg-sky-800" href={business.emailHref}>
      Email Tad
      <span class="mt-1 block text-sm font-bold">{business.email}</span>
    </a>
    <div class="grid grid-cols-2 gap-3">
      <a class="rounded-sm border border-sky-950/12 bg-sky-50 px-4 py-3 text-center text-sm font-black text-sky-950 transition hover:bg-sky-100" href={business.facebook} target="_blank" rel="noopener noreferrer">Facebook</a>
      <a class="rounded-sm border border-sky-950/12 bg-sky-50 px-4 py-3 text-center text-sm font-black text-sky-950 transition hover:bg-sky-100" href={business.zillow} target="_blank" rel="noopener noreferrer">Zillow</a>
    </div>
  </div>
</aside>
